# MassFlow - Variáveis de ambiente (referência / placeholders)
# Copie para .env local com valores reais. No Easypanel, use as mesmas chaves.

# ========== Backend ==========
# PostgreSQL - URL interna no Easypanel: postgres://user:senha@nome_servico_postgres:5432/massflow?sslmode=disable
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/massflow

JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS - domínios do frontend separados por vírgula
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Evolution API (base)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=

# Agentes SaaS
AGENTES_SAAS_API_URL=
AGENTES_SAAS_API_KEY=

# Redis (opcional)
REDIS_URL=

# ========== Frontend (build) ==========
# VITE_API_URL=https://api.seudominio.com
