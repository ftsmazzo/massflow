# MassFlow - Variáveis de ambiente (referência / placeholders)
# Copie para .env local com valores reais. No Easypanel, use as mesmas chaves.
# Assinatura/créditos: Stripe (integração depois).

# ========== Backend ==========
# PostgreSQL - URL interna no Easypanel: postgres://user:senha@nome_servico_postgres:5432/massflow?sslmode=disable
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/massflow

JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS - domínios do frontend separados por vírgula (sem https:// duplicado)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Opcional: regex para aceitar qualquer subdomínio (ex.: Easypanel)
# CORS_ORIGIN_REGEX=https://.*\.easypanel\.host

# Evolution API (base)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=

# Redis (opcional)
REDIS_URL=

# ========== Frontend (build - obrigatório em produção) ==========
# No Easypanel, no serviço do FRONTEND: defina VITE_API_URL no BUILD (Build Arg ou env no build):
#   VITE_API_URL = https://fabricaia-massflow-backend.xxx.easypanel.host
# Sem isso, o JS é compilado com URL vazia, as requisições vão para o domínio do front (nginx) e dão 405.
# VITE_API_URL=https://sua-url-do-backend
