# MassFlow - Variáveis de ambiente (referência / placeholders)
# Copie para .env local com valores reais. No Easypanel, use as mesmas chaves.
# Assinatura/créditos: Stripe (integração depois).

# ========== Backend ==========
# PostgreSQL - URL interna no Easypanel: postgres://user:senha@nome_servico_postgres:5432/massflow?sslmode=disable
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/massflow

# Opcional: Postgres do SaaS (ex.: chatMessages). Usuário só leitura recomendado. Vazio = desativado.
# SAAS_CHAT_HISTORY_DATABASE_URL=postgresql://usuario:senha@host:5435/saas_agentes?sslmode=require

JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS - no BACKEND: origem(s) do frontend que podem chamar a API.
# Em produção (Easypanel): use UMA URL, a do seu frontend, exatamente como o usuário acessa (sem barra no final).
# Erro comum: "https://https://..." (duplicado) ou esquecer de colar a URL do front.
# Desenvolvimento local:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Produção Easypanel (substitua pela URL real do SEU frontend):
# CORS_ORIGINS=https://fabricaia-massflow-frontend.iei9vc.easypanel.host

# Evolution API (base)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=

# Redis (opcional)
REDIS_URL=

# ========== Frontend (Easypanel - use proxy, sem CORS) ==========
# NÃO defina VITE_API_URL no build. No container do FRONTEND defina:
#   BACKEND_URL = http://fabricaia-massflow-backend:8000
# (nome interno do serviço backend no Easypanel + porta 8000)
# O nginx do front faz proxy de /api para o backend = mesma origem = zero CORS.
